# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:password@localhost:5432/shopsphere?schema=public"

# JWT
JWT_ACCESS_SECRET=replace_with_long_random_string_access
JWT_REFRESH_SECRET=replace_with_long_random_string_refresh
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Email (for verification + password reset links).
# Leave EMAIL_HOST blank during local dev — emails will just print to the
# backend console instead of failing, so you can copy the link out of the terminal.
# For real sending: Gmail (use an App Password, not your normal password),
# Mailtrap (great for testing), SendGrid, Resend, or Amazon SES all work.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="ShopSphere <no-reply@shopsphere.com>"
